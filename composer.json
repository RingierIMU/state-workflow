{
    "name": "ringierimu/state-workflow",
    "description": "Laravel State Workflow provide tools for defining and managing workflows and activities with ease.",
    "license": "MIT",
    "type": "library",
    "keywords": [
        "workflow",
        "state management",
        "state machine",
        "state workflow",
        "laravel"
    ],
    "authors": [
        {
            "name": "Norby Baruani",
            "email": "norbybaru@gmail.com",
            "role": "Developer"
        }
    ],
    "homepage": "https://github.com/RingierIMU/state-workflow",
    "require": {
        "php": "^8.3",
        "illuminate/events": "^11.0 || ^12.0",
        "illuminate/support": "^11.0 || ^12.0",
        "symfony/event-dispatcher": "^7.0",
        "symfony/property-access": "^7.0",
        "symfony/workflow": "^7.0"
    },
    "require-dev": {
        "mockery/mockery": "^1.3",
        "orchestra/testbench": "^9.15 || ^10.0",
        "pestphp/pest": "^4.0",
        "pestphp/pest-plugin-laravel": "^4.0"
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "autoload": {
        "psr-4": {
            "Ringierimu\\StateWorkflow\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Ringierimu\\StateWorkflow\\Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Ringierimu\\StateWorkflow\\StateWorkflowServiceProvider"
            ]
        }
    },
    "scripts": {
        "test": "vendor/bin/pest"
    }
}
